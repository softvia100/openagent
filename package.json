    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.12",
    "@types/uuid": "^9.0.8",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.2",
